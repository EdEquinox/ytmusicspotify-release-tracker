FRONTEND_PORT=3001
BACKEND_PORT=8001
REACT_APP_URL=http://127.0.0.1:3001
REACT_APP_BACKEND_URL=http://localhost:8001
REACT_APP_SPOTIFY_CLIENT_ID=
REACT_APP_SPOTIFY_REDIRECT_URI=http://localhost:3001/artists
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Worker runtime credentials
YTMUSIC_AUTH_FILE=/data/ytmusic_auth.json
# Opcional: preferir Definições → "YTMusic — user ID" (persistido). Se ambos vazios, conta predefinida.
YTMUSIC_USER=
# WORKER_DIAG=1 — logs extra por release (query, album_type) no worker principal.
# Quando todas as pesquisas YTM falham com HTML/JSON inválido, espera N segundos antes do próximo lote (default 300).
#WORKER_TRANSPORT_BACKOFF_SECONDS=300
# Com docker-compose: o worker fala com o API em http://backend:8000 (porta *dentro* do contentor).
# 8001 é só o mapeamento no teu PC (BACKEND_PORT). Não mudes WORKER_BACKEND_URL salvo caso especial
# (ex. worker fora do Docker: WORKER_BACKEND_URL=http://127.0.0.1:8001).
#WORKER_BACKEND_URL=http://backend:8000
#REVERSE_WORKER_BACKEND_URL=http://backend:8000

# Reverse worker: por defeito só Tidal (sem API Spotify). Vazio = segue ``reverse_tidal_only`` em settings.json.
# Força modo: REVERSE_TIDAL_ONLY=1 (só Tidal) ou =0 (Spotify API + playlist opcional).
REVERSE_TIDAL_ONLY=
REVERSE_YTMUSIC_AUTH_FILE=/data/ytmusic_auth.json
# Opcional: preferir Definições → "YTMusic reverse — user ID". Senão cai no user principal / YTMUSIC_USER.
REVERSE_YTMUSIC_USER=
REVERSE_SPOTIFY_CACHE_PATH=/data/spotify_oauth_cache_reverse.json
