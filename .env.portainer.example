# Container images (publish these before deploying stack)
FRONTEND_IMAGE=ghcr.io/your-user/ytmusic-release-tracker-frontend:latest
BACKEND_IMAGE=ghcr.io/your-user/ytmusic-release-tracker-backend:latest
WORKER_IMAGE=ghcr.io/your-user/ytmusic-release-tracker-worker:latest

# Exposed ports on server
FRONTEND_PORT=3001
BACKEND_PORT=8001

# Persistent data directory on server host
DATA_DIR=/opt/ytmusic-release-tracker/data

# Frontend runtime config
REACT_APP_URL=http://YOUR_SERVER_IP_OR_DOMAIN:3001
REACT_APP_BACKEND_URL=http://YOUR_SERVER_IP_OR_DOMAIN:8001
REACT_APP_SPOTIFY_CLIENT_ID=
REACT_APP_SPOTIFY_REDIRECT_URI=http://YOUR_SERVER_IP_OR_DOMAIN:3001/artists

# Backend credentials
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional defaults (can later be changed via Settings UI)
SPOTIFY_INCLUDE_GROUPS=album,single
SPOTIFY_MARKET=PT
LOCAL_FETCH_SPACING_MS=120
RELEASE_WORKERS=10
WORKER_BACKEND_RETRY_SECONDS=15
WORKER_IDLE_SECONDS=20
WORKER_PROCESSED_SLEEP_SECONDS=10
WORKER_ALBUM_AUDIO_ONLY_STRICT=true
YTMUSIC_PLAYLIST_ID=

# Worker auth / account
YTMUSIC_AUTH_FILE=/data/ytmusic_auth.json
YTMUSIC_USER=
